    {
      "type": "timeseries",
      "title": "Public root probe status",
      "description": "No /healthz, /readyz, or /metrics endpoint was found in the repo. This uses blackbox_exporter probing of the public main host as the current health fallback.",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 39
      },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_success{instance=~\".*${main_host:regex}.*\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
