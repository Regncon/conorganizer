          "selected": true,
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "options": [
          {
            "selected": true,
            "text": "Prometheus",
            "value": "Prometheus"
          }
        ]
      },
      {
        "name": "DS_LOKI",
        "label": "Loki",
        "type": "datasource",
        "query": "loki",
        "refresh": 1,
        "hide": 0,
        "current": {
          "selected": true,
          "text": "Loki",
          "value": "Loki"
        },
        "options": [
          {
            "selected": true,
            "text": "Loki",
            "value": "Loki"
          }
        ]
      },
      {
        "name": "node_instance",
        "label": "Node instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "query": "label_values(node_uname_info, instance)",
        "definition": "label_values(node_uname_info, instance)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "text": "All",
          "value": "$__all",
          "selected": true
        }
      },
      {
        "name": "loki_job",
        "label": "Loki job",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "${DS_LOKI}"
        },
        "query": "label_values(job)",
        "definition": "label_values(job)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "text": "All",
          "value": "$__all",
          "selected": true
        }
      },
      {
        "name": "main_host",
        "label": "Main host",
        "type": "constant",
        "query": "main.lekeplassen.regncon.no",
        "current": {
          "text": "main.lekeplassen.regncon.no",
          "value": "main.lekeplassen.regncon.no"
        }
      },
      {
        "name": "grafana_host",
        "label": "Grafana host",
        "type": "constant",
        "query": "grafana.regncon.no",
        "current": {
          "text": "grafana.regncon.no",
          "value": "grafana.regncon.no"
        }
      }
    ]
