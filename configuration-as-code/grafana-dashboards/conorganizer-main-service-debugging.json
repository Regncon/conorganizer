        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=~\"$loki_job\"} |~ \"conorganizer-main.service|conorganizer-main|error running server|could not initialize DB|event image directory|failed|panic\"",
