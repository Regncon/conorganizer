      "title": "Error signal",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "panels": []
    },
    {
      "type": "stat",
      "title": "Current app error signal",
      "description": "Shows app error-like log lines in the last 5 minutes. It uses repo logging conventions: JSON slog request lines and ERROR logs. Alert candidate: > 0.",
      "datasource": {
        "type": "loki",
        "uid": "${DS_LOKI}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 18
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({job=~\"$loki_job\"} |~ \"conorganizer-main|http request completed|database is locked|database is busy|panic|failed|error|ERROR|status_code\" |~ \"ERROR|error|failed|panic|status_code.:5[0-9][0-9]|database is locked|database is busy\" [5m]))",
          "queryType": "range"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "id": 7
    },
