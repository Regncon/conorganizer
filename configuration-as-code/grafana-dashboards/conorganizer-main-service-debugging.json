      "1h",
      "6h",
      "12h",
      "24h",
      "7d",
      "30d"
    ]
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "hide": 0,
