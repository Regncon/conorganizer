package rooms

templ VenueContainer(isStatic bool, staticRoom string) {
	<style>
        /* Containers */
        .venue-container {
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

        .floors-container {
            position: relative;
            perspective-origin: center;
            transition: transform 500ms ease-in-out;
            transform-style: preserve-3d;

        }
        .floors-container[topdown] {
        }
        .floors-container[isometric] {
            perspective: 2000px;
            transform: rotateX(60deg) rotateY(0deg) rotateZ(15deg)
        }

        /* floor svg styling */
        .floor {
            position: absolute;
            stroke-width: 2px;
            transition: all 200ms ease-in-out;

        }
        .floor[topdown] {
            transform: rotateX(0deg);
        }
        .floor[isometric] {
            shape-rendering: geometricPrecision;
            transform: rotateX(10deg);
        }
        .floor .shape {
            fill: white;
        }

        /* Room poly styling */
        .rooms {
            stroke: rgb(34, 34, 34);
            transition: all 200ms ease-in-out;
            fill: rgb(240, 240, 240);
        }
        .room {
            fill: rgb(255, 255, 255);
        }
        .room:hover {
            fill: rgb(255, 220, 220);
        }
        .room[active] {
            fill: rgb(255, 130, 130);
        }
        .room[active]:hover {
            fill: rgb(255, 170, 170);
        }
    </style>
	<div
		class="venue-container"
	>
		<div
			class="floors-container"
			data-signals="{mode: '2d', 'active-room': ''}"
			data-attr="{topdown: $mode == '2d', isometric: $mode == '3d'}"
		>
			@GenerateFloorSVG(VenueData[1], isStatic, staticRoom)
		</div>
	</div>
}
