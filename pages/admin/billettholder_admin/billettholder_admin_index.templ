package billettholderadmin

import (
	"database/sql"
	"fmt"
	"github.com/Regncon/conorganizer/layouts"
	"github.com/Regncon/conorganizer/service/live"
	"github.com/Regncon/conorganizer/service/userctx"
	"github.com/go-chi/chi/v5"
	"log/slog"
	"net/http"
)

func indexRoute(router chi.Router, db *sql.DB, logger *slog.Logger) {
	router.Get("/admin/billettholder/", func(w http.ResponseWriter, r *http.Request) {
		var ctx = r.Context()
		userInfo := userctx.GetUserRequestInfo(r.Context())
		if err := layouts.Base(
			"Billettholder Admin",
			userInfo,
            db,
			indexPage(),
		).Render(ctx, w); err != nil {
			logger.Error(fmt.Errorf("failed to render billettholder admin page: %w", err).Error(), "user_id", userInfo.Id)
		}
	})
}

templ indexPage() {
	<div id="billettholder-admin-container" data-init={ live.DatastarInit("/admin/billettholder/api/") }>
		<p>Billettholder Admin</p>
		<p>If you are seeing this message, please clear your cookies and refresh the page.</p>
	</div>
}
